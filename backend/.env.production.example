# =============================================================================
# .env — GJ Logística Backend (PRODUCCIÓN)
# =============================================================================
# ⚠️  Este archivo es solo un TEMPLATE. Copiar a .env en el servidor y
#     completar con los valores reales. NUNCA commitear el .env real a git.
#
# En el servidor:
#   cp backend/.env.production.example backend/.env
#   nano backend/.env
# =============================================================================

# ── Servidor ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4001

# ── Base de datos MySQL ───────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=gj_user
DB_PASSWORD=CAMBIAR_PASSWORD_SEGURA
DB_DATABASE=gj_logistica

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_SECRET_ALEATORIO_MUY_LARGO
JWT_EXPIRATION=8h

# ── Email (Gmail / SMTP) ──────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=f.depositomails@gmail.com
MAIL_PASS=CAMBIAR_APP_PASSWORD_GMAIL
MAIL_FROM="GJ Logística <f.depositomails@gmail.com>"

# ── ETL (base de datos fuente Dolibarr) ──────────────────────────────────────
# Solo necesario si se corre el ETL desde este servidor
SRC_DB_HOST=localhost
SRC_DB_PORT=3306
SRC_DB_USERNAME=root
SRC_DB_PASSWORD=CAMBIAR_PASSWORD_DOLIBARR
SRC_DB_DATABASE=dolibarr

# ── Seed (usuario admin inicial) ─────────────────────────────────────────────
# Solo usado por `npm run seed`
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=CAMBIAR_PASSWORD_ADMIN
