# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=secret
DB_NAME=deposito_erp

# JWT
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_EXPIRES_IN=7d

# App
PORT=3000
NODE_ENV=development

# Mailer (Gmail SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=f.depositomails@gmail.com
MAIL_PASS=app-password-here
MAIL_FROM=f.depositomails@gmail.com

# ──────────────────────────────────────────────────────────────────────────────
# ETL: Dolibarr source database (only needed when running `npm run etl`)
# Can be the same MySQL server as dest, with different DB_NAME.
# ──────────────────────────────────────────────────────────────────────────────
SRC_DB_HOST=localhost
SRC_DB_PORT=3306
SRC_DB_USER=root
SRC_DB_PASS=secret
SRC_DB_NAME=dolibarr

# Default password assigned to all migrated users (they must change it after login)
ETL_DEFAULT_PASSWORD=Temporal2026!
